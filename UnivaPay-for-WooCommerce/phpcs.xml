<?xml version="1.0"?>
<ruleset name="Univapay Plugin Coding Standards">
    <description>Ruleset for the Univapay Plugin</description>
    
    <config name="ignore_warnings_on_exit" value="true"/>

    <file>UnivaPay-for-WooCommerce.php</file>
    <file>includes</file>
    <file>tests</file>

    <rule ref="WordPress">
        <exclude name="Generic.Commenting.DocComment.MissingShort"/>
        <exclude name="Squiz.Commenting.FileComment.Missing"/>
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
        <exclude name="WordPress.Files.FileName"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>
    </rule>

    <exclude-pattern>bootstrap.php</exclude-pattern>
    
    <config name="testVersion" value="7.4-"/>
    <rule ref="PHPCompatibilityWP"/>

    <rule ref="Generic.PHP.ForbiddenFunctions">
        <properties>
            <property name="forbiddenFunctions" type="array">
                <element key="var_dump" value="null"/>
                <element key="print_r" value="null"/>
                <element key="error_log" value="null"/>
            </property>
        </properties>
    </rule>
</ruleset>
